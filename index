<body>
  <div id="particles"></div>
  <canvas id="confetti-canvas"></canvas>

  <header>
    <span class="logo-jazzcash">
      <img src="https://i.postimg.cc/94R7kgCR/jazzcash-logo.png" alt="JazzCash" onerror="this.style.display='none';">
      JazzCash
    </span>
  </header>

  <div class="container">
    <h1>CONGRATULATIONS!</h1>
    <h2>Answer & Win!</h2>
    <p class="sub">Answer simple questions to win 100,000 PKR <span style="color:var(--accent); font-weight:600;">₨100,000</span> Today!</p> <p class="sub">Thousands of Pakistanis are claiming their prize today — why miss out?</p>
   
    <div class="engagement">
      <span><div class="live-dot"></div> <span class="likes-text">❤️ 1,200+</span></span>
      <span>👁️ <span class="views-text">300,000+</span> Viewers</span>
    </div>

    <!-- QUIZ REPLACES WHEEL -->
    <div class="quiz-wrapper">
      <!-- Step 1: Do you need the money? -->
      <div class="quiz-step active" id="quizStep1">
        <span class="quiz-step-number">🔹 Question 1 of 2</span>
        <div class="quiz-question">Do you <span class="highlight">need the money</span>?</div>
        <div class="quiz-options horizontal">
          <div class="quiz-option" data-next="step2yes" data-purpose=""><span class="option-icon">✅</span> Yes</div>
          <div class="quiz-option" data-next="step2no" data-purpose=""><span class="option-icon">❌</span> No</div>
        </div>
      </div>
      <!-- Step 2 for YES: What do you want to use the money for? -->
      <div class="quiz-step" id="quizStep2Yes">
        <span class="quiz-step-number">🔹 Question 2 of 2</span>
        <div class="quiz-question">What do you want to <span class="highlight">use the money</span> for?</div>
        <div class="quiz-options">
          <div class="quiz-option" data-next="processing" data-purpose="repay your loan"><span class="option-icon">💰</span> Personal Use / Loan Coverage</div>
          <div class="quiz-option" data-next="processing" data-purpose="buy a house"><span class="option-icon">🏠</span> Buy House</div>
          <div class="quiz-option" data-next="processing" data-purpose="upgrade your business"><span class="option-icon">📈</span> Business Upgrade</div>
          <div class="quiz-option" data-next="processing" data-purpose="pay education fees"><span class="option-icon">🎓</span> Education Fees</div>
        </div>
      </div>
      <!-- Step 2 for NO: What do you want? -->
      <div class="quiz-step" id="quizStep2No">
        <span class="quiz-step-number">🔹 Question 2 of 2</span>
        <div class="quiz-question">What do <span class="highlight">you want</span>?</div>
        <div class="quiz-options">
          <div class="quiz-option" data-next="processing" data-purpose="buy an iPhone"><span class="option-icon">📱</span> iPhone</div>
          <div class="quiz-option" data-next="processing" data-purpose="buy a Bike"><span class="option-icon">🏍️</span> Bike</div>
