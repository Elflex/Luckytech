<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Quiz & Win | Exclusive Reward</title>
  <style>
    :root {
      --bg: #000000;
      --card-bg: #0a0a0a;
      --border: #222;
      --primary: #25D366;
      --accent: #FFD700;
      --text: #ffffff;
      --text-muted: #888888;
      --glow-green: rgba(37, 211, 102, 0.4);
      --glow-yellow: rgba(255, 215, 0, 0.3);
      --font-main: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-main);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      overflow-x: hidden;
      position: relative;
    }

    #particles {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
      overflow: hidden;
    }
    .particle {
      position: absolute;
      border-radius: 50%;
      opacity: 0.4;
      animation: float linear infinite;
    }
    @keyframes float {
      0% { transform: translateY(100vh) scale(0.8); opacity: 0; }
      15% { opacity: 0.6; }
      85% { opacity: 0.6; }
      100% { transform: translateY(-10vh) scale(1); opacity: 0; }
    }

    .container {
      width: 100%;
      max-width: 480px;
      padding: 16px 20px 80px;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    header {
      width: 100%;
      padding: 12px 24px;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 13px;
      letter-spacing: 2px;
      color: var(--text-muted);
      text-transform: lowercase;
      font-weight: 700;
    }
    .logo-jazzcash {
      color: #e80000;
      text-shadow: 0 0 10px rgba(232,0,0,0.5);
      letter-spacing: 2px;
      border-bottom: 2px solid var(--accent);
      padding-bottom: 4px;
      text-transform: lowercase;
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 800;
    }
    .logo-jazzcash img {
      height: 28px;
      object-fit: contain;
    }

    h1 {
      font-size: clamp(28px, 7vw, 40px);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      background: linear-gradient(to right, #fff 40%, var(--accent));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 20px var(--glow-yellow);
      margin-top: 10px;
      margin-bottom: 6px;
    }
    h2 {
      font-size: clamp(20px, 5vw, 26px);
      font-weight: 700;
      color: #FFD700;
      margin-bottom: 10px;
      text-shadow: 0 0 15px rgba(255,215,0,0.5);
    }
    .sub {
      font-size: 15px;
      color: var(--text-muted);
      max-width: 85%;
      line-height: 1.5;
      margin-bottom: 20px;
    }

    .engagement {
      display: flex;
      gap: 20px;
      justify-content: center;
      margin-bottom: 16px;
      font-size: 13px;
      font-weight: 500;
      color: #ccc;
      background: rgba(255,255,255,0.04);
      padding: 8px 14px;
      border-radius: 30px;
      border: 1px solid #1a1a1a;
    }
    .engagement span { display: flex; align-items: center; gap: 4px; white-space: nowrap; }
    .live-dot { width: 6px; height: 6px; background: #25D366; border-radius: 50%; display: inline-block; animation: blink 1.5s infinite; margin-right: 2px; }
    @keyframes blink { 50% { opacity: 0.3; } }

    /* QUIZ STYLES - MORE ATTRACTIVE */
    .quiz-wrapper {
      width: 100%;
      max-width: 360px;
      margin-bottom: 20px;
      background: linear-gradient(145deg, #0d0d0d 0%, #111 50%, #0a0a0a 100%);
      border: 1px solid #2a2a2a;
      border-radius: 24px;
      padding: 28px 22px;
      box-shadow: 0 0 40px rgba(255,215,0,0.1), 0 0 80px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.03);
      position: relative;
      overflow: hidden;
    }
    .quiz-wrapper::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 20%, rgba(255,215,0,0.03) 0%, transparent 50%),
                  radial-gradient(circle at 70% 80%, rgba(37,211,102,0.03) 0%, transparent 50%);
      pointer-events: none;
    }
    .quiz-step {
      display: none;
      position: relative;
      z-index: 1;
    }
    .quiz-step.active {
      display: block;
      animation: fadeInUp 0.4s ease-out;
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .quiz-step-number {
      display: inline-block;
      background: linear-gradient(135deg, var(--accent), #FFA500);
      color: #000;
      font-weight: 800;
      font-size: 11px;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 14px;
      letter-spacing: 1px;
      text-transform: uppercase;
    }
    .quiz-question {
      font-size: 19px;
      font-weight: 700;
      margin-bottom: 22px;
      color: #fff;
      line-height: 1.4;
    }
    .quiz-question .highlight {
      color: var(--accent);
    }
    .quiz-options {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .quiz-options.horizontal {
      flex-direction: row;
      gap: 14px;
    }
    .quiz-options.horizontal .quiz-option {
      flex: 1;
      text-align: center;
      justify-content: center;
      padding: 18px 14px;
    }
    .quiz-option {
      background: linear-gradient(135deg, #141414 0%, #0f0f0f 100%);
      border: 1.5px solid #2a2a2a;
      border-radius: 16px;
      padding: 16px 18px;
      font-size: 15px;
      font-weight: 600;
      color: #ddd;
      cursor: pointer;
      transition: all 0.3s ease;
      text-align: left;
      display: flex;
      align-items: center;
      gap: 12px;
      position: relative;
      overflow: hidden;
    }
    .quiz-option::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,215,0,0.05) 0%, transparent 50%);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .quiz-option:hover {
      border-color: var(--accent);
      background: linear-gradient(135deg, #1a1a1a 0%, #141414 100%);
      color: #fff;
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.4);
    }
    .quiz-option:hover::after {
      opacity: 1;
    }
    .quiz-option.selected {
      border-color: var(--primary);
      background: linear-gradient(135deg, #0d1a12 0%, #0a150f 100%);
      color: #fff;
      box-shadow: 0 0 20px var(--glow-green), 0 0 40px rgba(37,211,102,0.1);
      transform: translateY(-2px);
    }
    .quiz-option.selected .option-badge {
      background: var(--primary);
      color: #000;
    }
    .quiz-option .option-icon {
      font-size: 26px;
      flex-shrink: 0;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
    }
    .quiz-option .option-badge {
      width: 32px;
      height: 32px;
      border-radius: 10px;
      background: #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 800;
      font-size: 14px;
      flex-shrink: 0;
      transition: all 0.3s ease;
      border: 1px solid #333;
    }

    /* LOADING / PROCESSING SCREEN */
    .processing-screen {
      display: none;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      padding: 10px 0;
      position: relative;
      z-index: 1;
    }
    .processing-screen.active {
      display: flex;
      animation: fadeInUp 0.4s ease-out;
    }
    .processing-title {
      font-size: 18px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 6px;
      text-align: center;
    }
    .processing-title .pulse-icon {
      display: inline-block;
      animation: pulse-icon 1.5s infinite;
    }
    @keyframes pulse-icon {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.2); }
    }
    .processing-step {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 13px;
      color: #666;
      width: 100%;
      padding: 12px 16px;
      background: #0d0d0d;
      border-radius: 12px;
      border: 1px solid #1a1a1a;
      opacity: 0.5;
      transition: all 0.4s ease;
    }
    .processing-step.done {
      color: var(--primary);
      border-color: var(--primary);
      opacity: 1;
      background: #0d1a12;
    }
    .processing-step.done .step-icon {
      color: var(--primary);
    }
    .processing-step.active-step {
      color: #FFD700;
      border-color: #FFD700;
      opacity: 1;
      background: #1a1a0d;
      animation: pulse-step 1s infinite;
    }
    @keyframes pulse-step {
      0%, 100% { box-shadow: 0 0 8px rgba(255,215,0,0.15); }
      50% { box-shadow: 0 0 20px rgba(255,215,0,0.35); }
    }
    .step-icon {
      font-size: 18px;
      width: 26px;
      text-align: center;
      flex-shrink: 0;
    }
    .spinner-small {
      width: 20px;
      height: 20px;
      border: 2px solid #333;
      border-top: 2px solid #FFD700;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .sponsor {
      margin-top: 16px;
      font-size: 13px;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      opacity: 0.95;
      flex-wrap: wrap;
      background: rgba(255,255,255,0.03);
      padding: 10px 16px;
      border-radius: 40px;
      border: 1px solid #1a1a1a;
    }
    .sponsor-logo {
      height: 26px;
      object-fit: contain;
      filter: brightness(1.1) drop-shadow(0 2px 4px rgba(0,0,0,0.5));
      transition: transform 0.2s;
    }
    .sponsor-logo:hover { transform: scale(1.05); }
    .sponsor-separator {
      width: 1px;
      height: 20px;
      background: #333;
      margin: 0 2px;
    }
    .brand-tag {
      background: rgba(255,255,255,0.08);
      padding: 4px 12px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 11px;
      color: #ddd;
      letter-spacing: 0.5px;
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .brand-tag.hd {
      background: linear-gradient(135deg, #FFD700, #FFA500);
      color: #000;
      font-weight: 800;
    }

    #comments-section {
      width: 100%;
      max-width: 400px;
      margin-top: 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .section-label {
      font-size: 12px;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .comment-card {
      background: var(--card-bg);
      border: 1px solid #1a1a1a;
      padding: 10px 12px;
      border-radius: 12px;
      font-size: 13px;
      display: flex;
      align-items: center;
      gap: 10px;
      animation: slideIn 0.3s ease-out forwards;
      opacity: 0;
      transform: translateY(-5px);
    }
    .comment-avatar {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: linear-gradient(135deg, #333, #111);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      color: #fff;
      font-weight: 600;
      border: 1px solid #333;
    }
    .comment-content { display: flex; flex-direction: column; text-align: left; }
    .comment-name { color: #aaa; font-weight: 500; font-size: 12px; }
    .comment-text { color: #eee; line-height: 1.3; margin-top: 2px; }
    @keyframes slideIn { to { opacity: 1; transform: translateY(0); } }

    .comment-input-wrap {
      display: flex;
      gap: 8px;
      margin-top: 10px;
      background: #0f0f0f;
      border: 1px solid #252525;
      border-radius: 50px;
      padding: 6px;
    }
    #userComment {
      flex: 1;
      background: transparent;
      border: none;
      color: #fff;
      padding: 8px 14px;
      font-size: 13px;
      outline: none;
    }
    #userComment::placeholder { color: #555; }
    #postComment {
      background: var(--primary);
      color: #000;
      border: none;
      border-radius: 30px;
      padding: 8px 16px;
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
    }
    #postComment:disabled { opacity: 0.5; cursor: default; }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.88);
      backdrop-filter: blur(14px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 100;
      padding: 20px;
    }
    #initialModal {
      display: flex;
    }
    .modal {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 26px 22px;
      width: 100%;
      max-width: 340px;
      text-align: center;
      box-shadow: 0 20px 50px rgba(0,0,0,0.85);
      animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    @keyframes popIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .modal h3 { font-size: 18px; font-weight: 800; margin-bottom: 8px; color: #fff; line-height: 1.4; }
    .modal p { font-size: 13px; color: #999; margin-bottom: 14px; line-height: 1.4; }
    .modal-info {
      background: #0d0d0d;
      border-radius: 12px;
      padding: 14px;
      margin-bottom: 16px;
      text-align: left;
      font-size: 13px;
      color: #bbb;
      border: 1px solid #2a2a2a;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #1f1f1f;
      padding-bottom: 8px;
    }
    .info-row:last-child { border-bottom: none; padding-bottom: 0; }
    .info-label { color: #888; font-weight: 500; }
    .info-value { color: #fff; font-weight: 600; display: flex; align-items: center; gap: 5px; }
    .modern-badge {
      background: #1a2a1f;
      color: #25D366;
      padding: 2px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    .modal-sponsor {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 12px;
      padding: 10px;
      background: rgba(255,255,255,0.03);
      border-radius: 12px;
      font-size: 12px;
      color: #aaa;
      flex-wrap: wrap;
    }
    .modal-sponsor img {
      height: 22px;
      object-fit: contain;
      filter: brightness(1.1);
    }
    .money-img {
      font-size: 55px;
      margin: 15px 0;
    }

    .emergency-timer {
      background: #1a0000;
      border: 2px solid #ff0000;
      border-radius: 12px;
      padding: 12px;
      margin: 15px 0;
      color: #ff4444;
      font-weight: 700;
      font-size: 14px;
    }
    .timer-display {
      font-size: 32px;
      font-weight: 800;
      color: #ff0000;
      letter-spacing: 2px;
      animation: pulse-red 1s infinite;
    }
    @keyframes pulse-red {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.6; }
    }
    .timer-label {
      font-size: 12px;
      color: #ff6666;
      margin-top: 4px;
    }
    .limited-offer {
      background: linear-gradient(135deg, #FFD700, #FFA500);
      color: #000;
      padding: 6px 14px;
      border-radius: 20px;
      font-weight: 800;
      font-size: 12px;
      display: inline-block;
      margin: 8px 0;
      letter-spacing: 1px;
    }

    .scarcity-note {
      background: rgba(255,215,0,0.1);
      border: 1px solid rgba(255,215,0,0.3);
      border-radius: 10px;
      padding: 10px;
      margin: 10px 0;
      color: #FFD700;
      font-weight: 700;
      font-size: 13px;
      animation: glow-pulse 2s infinite;
    }
    @keyframes glow-pulse {
      0%, 100% { box-shadow: 0 0 5px rgba(255,215,0,0.2); }
      50% { box-shadow: 0 0 15px rgba(255,215,0,0.5); }
    }

    .btn-primary, .btn-proceed, .btn-ok {
      width: 100%;
      padding: 13px;
      border: none;
      border-radius: 50px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-bottom: 8px;
      transition: all 0.2s;
    }
    .btn-primary { background: var(--primary); color: #000; box-shadow: 0 4px 12px rgba(37,211,102,0.3); }
    .btn-proceed { 
      background: var(--primary); 
      color: #000; 
      box-shadow: 0 4px 12px rgba(37,211,102,0.3);
      animation: bounce-btn 0.8s infinite;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 1px;
    }
    @keyframes bounce-btn {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); box-shadow: 0 8px 20px rgba(37,211,102,0.5); }
    }
    .btn-ok { background: #fff; color: #000; margin-top: 6px; }

    .hidden { display: none !important; }
    @media(max-width:360px) { .quiz-wrapper { width: 290px; padding: 22px 16px; } }

    #confetti-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 200;
    }
